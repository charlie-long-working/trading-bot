# Glassnode API key for on-chain metrics (SOPR, MVRV).
# Get a key at https://glassnode.com (free tier available; rate limits apply).
# If not set, the bot falls back to cached CSV in data/onchain/{asset}/ when available.
GLASSNODE_API_KEY=your_glassnode_api_key_here

# Telegram: báo tín hiệu Long/Short + TP/SL (khung 1h).
# Tạo bot: @BotFather -> /newbot -> dán token vào TELEGRAM_BOT_TOKEN.
# Lấy chat_id: gửi /start cho bot, mở https://api.telegram.org/bot<TOKEN>/getUpdates, tìm "chat":{"id":...}.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OKX: bot giao dịch tự động (run_okx_bot.py).
# Tạo API key tại https://www.okx.com/account/my-api (cần quyền Trade, Read).
# OKX_DEMO=1 để dùng tài khoản demo (nếu có).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# OKX_DEMO=0
