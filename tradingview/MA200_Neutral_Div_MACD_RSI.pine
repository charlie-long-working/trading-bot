// MA200 + Neutral index + MACD/RSI divergence
// - MA200: SMA(close, 200)
// - MA200 step/deviation: (close - MA200) / MA200 * 100 (%)
// - Neutral ON: based on MA spread + volatility contraction (similar to Neutral_Bot_Index)
// - Divergence: price vs MACD line and price vs RSI(14) using pivots

//@version=5
indicator("MA200 Neutral + MACD/RSI Divergence", overlay=true, max_labels_count=20)

// ═══════════════════════════════════════════════════════════════════════
// Inputs: MA200 + Deviation
// ═══════════════════════════════════════════════════════════════════════

i_ma200Period = input.int(200, "MA200 period", minval=2, group="MA200")
i_showMA200 = input.bool(true, "Show MA200", group="MA200")
i_showLastLabel = input.bool(true, "Show last bar label (MA200/Dev/Neutral)", group="MA200")

// ═══════════════════════════════════════════════════════════════════════
// Inputs: Neutral index
// ═══════════════════════════════════════════════════════════════════════

g_neutral = "Neutral index"
i_shortMa = input.int(20, "MA short", group=g_neutral, minval=1)
i_longMa = input.int(50, "MA long", group=g_neutral, minval=1)
i_volPeriod = input.int(20, "Volatility (stdev window)", group=g_neutral, minval=2)

g_neutral_filter = "Neutral thresholds"
i_maxSpreadPct = input.float(1.0, "Max MA spread (%)", group=g_neutral_filter, minval=0.05, step=0.05)
i_maxVolRatio = input.float(0.8, "Max volRatio (contraction)", group=g_neutral_filter, minval=0.05, step=0.05)
i_minVolRatio = input.float(0.2, "Min volRatio (score=100)", group=g_neutral_filter, minval=0.05, step=0.05)

i_useMa200Filter = input.bool(true, "Use MA200 distance filter", group=g_neutral_filter)
i_maxMa200DistPct = input.float(10.0, "Max |price-MA200| (%)", group=g_neutral_filter, minval=0.5, step=0.5)

i_threshold = input.float(70.0, "Neutral score threshold", group=g_neutral_filter, minval=0, maxval=100, step=1)

g_neutral_show = "Neutral show"
i_showNeutralBg = input.bool(true, "Background when Neutral ON", group=g_neutral_show)

f_clamp(_x, _min, _max) =>
    math.max(_min, math.min(_max, _x))

shortMa = ta.sma(close, i_shortMa)
longMa = ta.sma(close, i_longMa)

spreadPct = (not na(longMa) and longMa != 0.0) ? math.abs(shortMa - longMa) / longMa * 100.0 : na

recentStd = ta.stdev(close, i_volPeriod)
prevStd = ta.stdev(close[i_volPeriod], i_volPeriod)
volRatio = (prevStd > 0.0) ? recentStd / prevStd : na
volContracting = not na(volRatio) and volRatio <= i_maxVolRatio

trendScore = not na(spreadPct) ? f_clamp(100.0 * (1.0 - spreadPct / i_maxSpreadPct), 0.0, 100.0) : 0.0
volScore = not na(volRatio) ? f_clamp(100.0 * (i_maxVolRatio - volRatio) / math.max(i_maxVolRatio - i_minVolRatio, 0.0001), 0.0, 100.0) : 0.0

ma200 = ta.sma(close, i_ma200Period)
ma200DistPct = (not na(ma200) and ma200 != 0.0) ? math.abs(close - ma200) / ma200 * 100.0 : na
ma200Score = i_useMa200Filter and not na(ma200DistPct) ? f_clamp(100.0 * (1.0 - ma200DistPct / i_maxMa200DistPct), 0.0, 100.0) : 50.0

neutralScore = 0.45 * trendScore + 0.35 * volScore + 0.20 * ma200Score
neutralMode = neutralScore >= i_threshold and volContracting

// ═══════════════════════════════════════════════════════════════════════
// Inputs: Divergence (MACD & RSI)
// ═══════════════════════════════════════════════════════════════════════

g_div = "Divergence"
i_pivotLeft = input.int(5, "Pivot left bars", group=g_div, minval=1)
i_pivotRight = input.int(5, "Pivot right bars (confirmation)", group=g_div, minval=1)

i_showMacdDiv = input.bool(true, "Show MACD divergence", group=g_div)
i_showRsiDiv = input.bool(true, "Show RSI divergence", group=g_div)

// MACD params
i_macdFast = input.int(12, "MACD fast", group=g_div, minval=1)
i_macdSlow = input.int(26, "MACD slow", group=g_div, minval=2)
i_macdSignal = input.int(9, "MACD signal", group=g_div, minval=1)

// RSI params
i_rsiLen = input.int(14, "RSI length", group=g_div, minval=2)

[macdLine, macdSignalLine, macdHist] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSignal)
rsi = ta.rsi(close, i_rsiLen)

// Pivot helpers (value appears on confirmation bar)
plPrice = ta.pivotlow(low, i_pivotLeft, i_pivotRight)
phPrice = ta.pivothigh(high, i_pivotLeft, i_pivotRight)

// Store previous pivots for divergence detection
var float prevPLPrice_macd = na
var float prevPLMacd = na
var float prevPHPrice_macd = na
var float prevPHMacd = na

var float prevPLPrice_rsi = na
var float prevPLRsi = na
var float prevPHPrice_rsi = na
var float prevPHRsi = na

// Signals
bullDivMacd = false
bearDivMacd = false
bullDivRsi = false
bearDivRsi = false

// Bullish divergence (price lower low, MACD/RSI higher low) on pivot lows
if not na(plPrice)
    // pivot low on price confirmed at current bar, so indicator values are i_pivotRight bars ago
    macdAtPL = macdLine[i_pivotRight]
    rsiAtPL = rsi[i_pivotRight]

    bullDivMacd := not na(prevPLPrice_macd) and plPrice < prevPLPrice_macd and not na(macdAtPL) and macdAtPL > prevPLMacd
    prevPLPrice_macd := plPrice
    prevPLMacd := macdAtPL

    bullDivRsi := not na(prevPLPrice_rsi) and plPrice < prevPLPrice_rsi and not na(rsiAtPL) and rsiAtPL > prevPLRsi
    prevPLPrice_rsi := plPrice
    prevPLRsi := rsiAtPL

// Bearish divergence (price higher high, MACD/RSI lower high) on pivot highs
if not na(phPrice)
    // pivot high on price confirmed at current bar
    macdAtPH = macdLine[i_pivotRight]
    rsiAtPH = rsi[i_pivotRight]

    bearDivMacd := not na(prevPHPrice_macd) and phPrice > prevPHPrice_macd and not na(macdAtPH) and macdAtPH < prevPHMacd
    prevPHPrice_macd := phPrice
    prevPHMacd := macdAtPH

    bearDivRsi := not na(prevPHPrice_rsi) and phPrice > prevPHPrice_rsi and not na(rsiAtPH) and rsiAtPH < prevPHRsi
    prevPHPrice_rsi := phPrice
    prevPHRsi := rsiAtPH

// Plot MA200
plot(i_showMA200 ? ma200 : na, "MA200", color=color.new(color.blue, 0), linewidth=2)

// Plot Neutral background
bgcolor(i_showNeutralBg and neutralMode ? color.new(color.lime, 85) : na)

// Plot divergence shapes (offset to pivot bar)
plotshape(i_showMacdDiv and bullDivMacd, title="Bull MACD div", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="MACD", textcolor=color.black, offset=-i_pivotRight)
plotshape(i_showMacdDiv and bearDivMacd, title="Bear MACD div", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="MACD", textcolor=color.black, offset=-i_pivotRight)

plotshape(i_showRsiDiv and bullDivRsi, title="Bull RSI div", style=shape.circle, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="RSI", textcolor=color.black, offset=-i_pivotRight)
plotshape(i_showRsiDiv and bearDivRsi, title="Bear RSI div", style=shape.circle, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="RSI", textcolor=color.black, offset=-i_pivotRight)

// MA200 step/deviation
devPct = (not na(ma200) and ma200 != 0.0) ? (close - ma200) / ma200 * 100.0 : na

// Optional label on last bar only (no table)
var label lastInfoLbl = na
if i_showLastLabel and barstate.islast
    devStr = na(devPct) ? "—" : str.tostring(devPct, "#.##") + "%"
    neStr = "OFF"
    neColor = color.new(color.red, 0)
    if neutralMode
        neStr := "ON"
        neColor := color.new(color.lime, 0)
    txt = "MA200: " + str.tostring(ma200, "#.##")
    txt := txt + "\nDev: " + devStr
    txt := txt + "\nNeutral: " + neStr + " (" + str.tostring(neutralScore, "#.0") + ")"

    if na(lastInfoLbl)
        lastInfoLbl := label.new(bar_index, high, txt, style=label.style_label_down, textcolor=color.white, color=neColor, size=size.small)
    else
        label.set_xy(lastInfoLbl, bar_index, high)
        label.set_text(lastInfoLbl, txt)
        label.set_color(lastInfoLbl, neColor)

