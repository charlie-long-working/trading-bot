// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0.
// © Regime Fusion — Strategy: Regime + Order Blocks + FVG + Supply/Demand + Volume
// Khuyến nghị: khung 1h. Trên 1D giảm lookback hoặc tăng "Max tuổi vùng".

//@version=5
indicator("Regime Fusion - Mua/Bán", overlay=true, max_labels_count=500, max_boxes_count=500, max_lines_count=2)

// ═══════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════

// Regime
g_regime = "Regime (MA)"
i_shortMa    = input.int(20, "MA ngắn", group=g_regime, minval=1)
i_longMa     = input.int(50, "MA dài", group=g_regime, minval=1)
i_volPeriod  = input.int(20, "Chu kỳ volatility", group=g_regime, minval=1)

// Order Block
g_ob = "Order Block"
i_obLookback = input.int(50, "Lookback", group=g_ob, minval=5)
i_obMoveBars = input.int(5, "Số nến xác nhận move", group=g_ob, minval=1)
i_obMinPct   = input.float(0.5, "Min move %", group=g_ob, minval=0.1, step=0.1)

// Fair Value Gap
g_fvg = "Fair Value Gap"
i_fvgLookback = input.int(30, "Lookback", group=g_fvg, minval=3)

// Supply / Demand
g_zone = "Supply / Demand"
i_zoneLookback   = input.int(50, "Lookback", group=g_zone, minval=5)
i_zoneBaseBars  = input.int(3, "Số nến base", group=g_zone, minval=2)
i_zoneExpansion = input.float(0.3, "Expansion %", group=g_zone, minval=0.1, step=0.1)

// Bộ lọc
g_filter = "Bộ lọc"
i_maxZoneBars   = input.int(20, "Max tuổi vùng (bars)", group=g_filter, minval=5, maxval=100)
i_tolerancePct = input.float(0.1, "Tolerance % (price at zone)", group=g_filter, minval=0.01, step=0.05)
i_volumeConfirm = input.bool(false, "Bắt buộc volume >= SMA(20)", group=g_filter)

// Hiển thị
g_plot = "Hiển thị"
i_showMA     = input.bool(true, "Vẽ MA", group=g_plot)
i_showBg     = input.bool(true, "Nền regime (xanh/đỏ nhạt)", group=g_plot)
i_showSLTP   = input.bool(true, "Vẽ đường SL & TP", group=g_plot)
i_slTpBars   = input.int(50, "SL/TP kéo dài (bars)", group=g_plot, minval=5, maxval=200)

// Webhook (TradingView -> server -> OKX)
g_webhook = "Webhook OKX"
i_webhookEnable = input.bool(false, "Gửi webhook (alert()) khi có tín hiệu", group=g_webhook)
i_webhookMarket = input.string("swap", "market", group=g_webhook, options=["swap", "spot"], tooltip="swap=USDT-SWAP, spot=spot")
i_webhookSizeUsdt = input.float(100.0, "Size mỗi lệnh (USDT)", group=g_webhook, minval=0.0, step=10.0)

// ═══════════════════════════════════════════════════════════════════════
// REGIME
// Bull: MA ngắn > MA dài và không co volatility
// Bear: MA ngắn < MA dài
// Sideways: còn lại
// ═══════════════════════════════════════════════════════════════════════

shortMa = ta.sma(close, i_shortMa)
longMa  = ta.sma(close, i_longMa)
recentStd = ta.stdev(close, i_volPeriod)
prevStd   = ta.stdev(close[i_volPeriod], i_volPeriod)
volContracting = prevStd > 0 and recentStd < prevStd * 0.8

isBull = shortMa > longMa and not volContracting
isBear = shortMa < longMa

allowLong  = isBull or (not isBear)   // Bull hoặc Sideways
allowShort = isBear or (not isBull)   // Bear hoặc Sideways

// ═══════════════════════════════════════════════════════════════════════
// VOLUME
// ═══════════════════════════════════════════════════════════════════════

volSma = ta.sma(volume, 20)
volOk  = not i_volumeConfirm or (volume >= volSma)

// ═══════════════════════════════════════════════════════════════════════
// ORDER BLOCKS
// Bullish OB: nến bearish/doji tại [j], trong vài nến sau có close >= high[j]*(1+minPct%)
// Bearish OB: nến bullish/doji tại [j], trong vài nến sau có close <= low[j]*(1-minPct%)
// Chỉ lấy OB gần nhất mà giá hiện tại nằm trong vùng (có tolerance).
// ═══════════════════════════════════════════════════════════════════════

float bullObHigh = na
float bullObLow  = na
float bearObHigh = na
float bearObLow  = na

obMaxJ = math.min(i_obLookback - 1, i_maxZoneBars)
if bar_index >= i_obLookback + i_obMoveBars
    for j = i_obMoveBars to obMaxJ
        o_j = open[j]
        h_j = high[j]
        l_j = low[j]
        c_j = close[j]
        bearish = c_j <= o_j or math.abs(c_j - o_j) < o_j * 0.001
        bool strongUp = false
        for k = 1 to i_obMoveBars
            if close[j - k] >= h_j * (1 + i_obMinPct / 100)
                strongUp := true
                break
        tol = (h_j - l_j) * (i_tolerancePct / 100)
        if bearish and strongUp and close <= h_j + tol and close >= l_j - tol
            bullObHigh := h_j
            bullObLow  := l_j
            break
    for j = i_obMoveBars to obMaxJ
        o_j = open[j]
        h_j = high[j]
        l_j = low[j]
        c_j = close[j]
        bullish = c_j > o_j or math.abs(c_j - o_j) < o_j * 0.001
        bool strongDn = false
        for k = 1 to i_obMoveBars
            if close[j - k] <= l_j * (1 - i_obMinPct / 100)
                strongDn := true
                break
        tol = (h_j - l_j) * (i_tolerancePct / 100)
        if bullish and strongDn and close <= h_j + tol and close >= l_j - tol
            bearObHigh := h_j
            bearObLow  := l_j
            break

atBullOb = not na(bullObHigh)
atBearOb = not na(bearObHigh)

// ═══════════════════════════════════════════════════════════════════════
// FAIR VALUE GAPS (3 nến)
// Bullish FVG: high[j] < low[j-2] → gap [high[j], low[j-2]]
// Bearish FVG: low[j] > high[j-2] → gap [high[j-2], low[j]]
// ═══════════════════════════════════════════════════════════════════════

float bullFvgTop = na
float bullFvgBot = na
float bearFvgTop = na
float bearFvgBot = na

fvgMaxJ = math.min(i_fvgLookback - 1, i_maxZoneBars)
if bar_index >= i_fvgLookback
    for j = 2 to fvgMaxJ
        if high[j] < low[j - 2]
            top = low[j - 2]
            bot = high[j]
            tol = (top - bot) * (i_tolerancePct / 100)
            if close >= bot - tol and close <= top + tol
                bullFvgTop := top
                bullFvgBot := bot
                break
    for j = 2 to fvgMaxJ
        if low[j] > high[j - 2]
            top = low[j]
            bot = high[j - 2]
            tol = (top - bot) * (i_tolerancePct / 100)
            if close >= bot - tol and close <= top + tol
                bearFvgTop := top
                bearFvgBot := bot
                break

atBullFvg = not na(bullFvgTop)
atBearFvg = not na(bearFvgTop)

// ═══════════════════════════════════════════════════════════════════════
// SUPPLY / DEMAND ZONES
// Base = 3 nến tại j, j-1, j-2; nến mở rộng = j-3.
// Demand: close[j-3] > baseHigh + expansion%
// Supply: close[j-3] < baseLow - expansion%
// ═══════════════════════════════════════════════════════════════════════

float demandTop = na
float demandBot = na
float supplyTop = na
float supplyBot = na

zoneMaxJ = math.min(i_zoneLookback - 1, i_maxZoneBars)
if bar_index >= i_zoneLookback + i_zoneBaseBars
    for j = i_zoneBaseBars to zoneMaxJ
        baseHigh = math.max(high[j], math.max(high[j-1], high[j-2]))
        baseLow  = math.min(low[j], math.min(low[j-1], low[j-2]))
        mid = (baseHigh + baseLow) / 2
        if mid > 0
            expClose = close[j - i_zoneBaseBars]
            if (expClose - baseHigh) / mid * 100 >= i_zoneExpansion
                tol = (baseHigh - baseLow) * (i_tolerancePct / 100)
                if close >= baseLow - tol and close <= baseHigh + tol
                    demandTop := baseHigh
                    demandBot  := baseLow
                    break
    for j = i_zoneBaseBars to zoneMaxJ
        baseHigh = math.max(high[j], math.max(high[j-1], high[j-2]))
        baseLow  = math.min(low[j], math.min(low[j-1], low[j-2]))
        mid = (baseHigh + baseLow) / 2
        if mid > 0
            expClose = close[j - i_zoneBaseBars]
            if (baseLow - expClose) / mid * 100 >= i_zoneExpansion
                tol = (baseHigh - baseLow) * (i_tolerancePct / 100)
                if close >= baseLow - tol and close <= baseHigh + tol
                    supplyTop := baseHigh
                    supplyBot  := baseLow
                    break

atDemand = not na(demandTop)
atSupply = not na(supplyTop)

// ═══════════════════════════════════════════════════════════════════════
// FUSION: Long khi regime cho phép + (ở Bull OB hoặc Bull FVG hoặc Demand) + volume ok
// Short tương tự. Chỉ vẽ tín hiệu khi vừa chuyển từ không có → có.
// ═══════════════════════════════════════════════════════════════════════

longSignal  = allowLong and volOk and (atBullOb or atBullFvg or atDemand)
shortSignal = allowShort and volOk and (atBearOb or atBearFvg or atSupply)

longCond  = longSignal and not longSignal[1]
shortCond = shortSignal and not shortSignal[1]

// ═══════════════════════════════════════════════════════════════════════
// SL / TP (theo strategy: Bear 2% SL 3% TP, Bull 3% SL không TP, Sideways 1.5% SL 2% TP)
// Long: SL = đáy vùng (OB/FVG/demand) hoặc close*(1-stop%); TP = close*(1+tp%) hoặc không (bull)
// Short: SL = đỉnh vùng (OB/FVG/supply) hoặc close*(1+stop%); TP = close*(1-tp%)
// ═══════════════════════════════════════════════════════════════════════

float longSl  = na
float longTp  = na
float shortSl = na
float shortTp = na

if longCond
    longSl := atBullOb ? bullObLow : (atBullFvg ? bullFvgBot : (atDemand ? demandBot : close * (1 - (isBear ? 0.02 : (isBull ? 0.03 : 0.015)))))
    longTp := isBull ? na : (isBear ? close * 1.03 : close * 1.02)
if shortCond
    shortSl := atBearOb ? bearObHigh : (atBearFvg ? bearFvgTop : (atSupply ? supplyTop : close * (1 + (isBear ? 0.02 : 0.015))))
    shortTp := isBear ? close * 0.97 : close * 0.98

var line slLine = na
var line tpLine = na
var label sigLabel = na

if (longCond or shortCond) and i_showSLTP
    if not na(slLine)
        line.delete(slLine)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(sigLabel)
        label.delete(sigLabel)
    if longCond
        slLine := line.new(bar_index, longSl, bar_index + i_slTpBars, longSl, color=color.red, width=2)
        line.set_style(slLine, line.style_dashed)
        if not na(longTp)
            tpLine := line.new(bar_index, longTp, bar_index + i_slTpBars, longTp, color=color.green, width=2)
            line.set_style(tpLine, line.style_dashed)
        sigLabel := label.new(
             bar_index,
             high,
             "LONG"
                 + "\nEntry: " + str.tostring(close, "#.##")
                 + "\nSL: " + str.tostring(longSl, "#.##")
                 + "\nTP: " + (na(longTp) ? "—" : str.tostring(longTp, "#.##")),
             style     = label.style_label_down,
             color     = color.new(#4CAF50, 20),
             textcolor = color.white,
             size      = size.small)
    else
        slLine := line.new(bar_index, shortSl, bar_index + i_slTpBars, shortSl, color=color.red, width=2)
        line.set_style(slLine, line.style_dashed)
        tpLine := line.new(bar_index, shortTp, bar_index + i_slTpBars, shortTp, color=color.green, width=2)
        line.set_style(tpLine, line.style_dashed)
        sigLabel := label.new(
             bar_index,
             low,
             "SHORT"
                 + "\nEntry: " + str.tostring(close, "#.##")
                 + "\nSL: " + str.tostring(shortSl, "#.##")
                 + "\nTP: " + str.tostring(shortTp, "#.##"),
             style     = label.style_label_up,
             color     = color.new(#f44336, 20),
             textcolor = color.white,
             size      = size.small)

// ═══════════════════════════════════════════════════════════════════════
// TradingView alert() payload (JSON) for webhook relay server
// Note: In Alerts UI, choose "Any alert() function call".
// ═══════════════════════════════════════════════════════════════════════

f_numOrNull(_x) =>
    na(_x) ? "null" : str.tostring(_x, "#.##")

tvSymbolOKX = syminfo.basecurrency + syminfo.currency // e.g. BTC + USDT => BTCUSDT
tvEntry = close

if i_webhookEnable and longCond
    msg = "{"
        + "\"symbol\":\"" + tvSymbolOKX + "\","
        + "\"market\":\"" + i_webhookMarket + "\","
        + "\"side\":\"buy\","
        + "\"entry\":" + str.tostring(tvEntry, "#.##") + ","
        + "\"sl\":" + f_numOrNull(longSl) + ","
        + "\"tp\":" + f_numOrNull(longTp) + ","
        + "\"size_usdt\":" + str.tostring(i_webhookSizeUsdt, "#.##") + ","
        + "\"strategy\":\"regime_fusion\","
        + "\"signal\":\"long\""
        + "}"
    alert(msg, alert.freq_once_per_bar_close)

if i_webhookEnable and shortCond
    msg = "{"
        + "\"symbol\":\"" + tvSymbolOKX + "\","
        + "\"market\":\"" + i_webhookMarket + "\","
        + "\"side\":\"sell\","
        + "\"entry\":" + str.tostring(tvEntry, "#.##") + ","
        + "\"sl\":" + f_numOrNull(shortSl) + ","
        + "\"tp\":" + f_numOrNull(shortTp) + ","
        + "\"size_usdt\":" + str.tostring(i_webhookSizeUsdt, "#.##") + ","
        + "\"strategy\":\"regime_fusion\","
        + "\"signal\":\"short\""
        + "}"
    alert(msg, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════
// PLOT
// Tam giác xanh lên (dưới nến) = LONG (Mua). Tam giác đỏ xuống (trên nến) = SHORT (Bán).
// ═══════════════════════════════════════════════════════════════════════

plot(i_showMA ? shortMa : na, "MA ngắn", color=color.new(#2196F3, 0), linewidth=2)
plot(i_showMA ? longMa : na, "MA dài", color=color.new(#FF9800, 0), linewidth=2)

plotshape(longCond, "LONG (Mua)", shape.triangleup, location.belowbar, color.new(#4CAF50, 0), size=size.normal)
plotshape(shortCond, "SHORT (Bán)", shape.triangledown, location.abovebar, color.new(#f44336, 0), size=size.normal)

bgcolor(i_showBg ? (isBull ? color.new(#4CAF50, 92) : (isBear ? color.new(#f44336, 92) : na)) : na)

// ═══════════════════════════════════════════════════════════════════════
// ALERTS (webhook OKX)
// ═══════════════════════════════════════════════════════════════════════

alertcondition(longCond, "Regime Fusion - Long", "Tín hiệu MUA (Long)")
alertcondition(shortCond, "Regime Fusion - Short", "Tín hiệu BÁN (Short)")
